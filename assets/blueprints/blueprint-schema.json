{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "blueprint-schema.json",
  "title": "FacturaScripts Playground Blueprint",
  "description": "Schema for browser-applied FacturaScripts Playground blueprints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "debug": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "landingPage": {
      "type": "string"
    },
    "siteOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "locale": { "type": "string" },
        "timezone": { "type": "string" }
      }
    },
    "login": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string", "minLength": 1 }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "string",
            "minLength": 1
          },
          {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "name": { "type": "string" },
              "state": {
                "type": "string",
                "enum": ["install", "activate"]
              },
              "source": {
                "oneOf": [
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "type": { "type": "string", "enum": ["bundled"] }
                    }
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["url"],
                    "properties": {
                      "type": { "type": "string", "enum": ["url"] },
                      "url": { "type": "string", "format": "uri-reference" }
                    }
                  }
                ]
              }
            }
          }
        ]
      }
    },
    "seed": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "customers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "codcliente": { "type": "string" },
              "nombre": { "type": "string" },
              "razonsocial": { "type": "string" },
              "cifnif": { "type": "string" },
              "tipoidfiscal": { "type": "string" },
              "regimeniva": { "type": "string" },
              "email": { "type": "string" },
              "telefono1": { "type": "string" },
              "telefono2": { "type": "string" },
              "direccion": { "type": "string" },
              "apartado": { "type": "string" },
              "codpostal": { "type": "string" },
              "ciudad": { "type": "string" },
              "provincia": { "type": "string" },
              "codpais": { "type": "string" },
              "observaciones": { "type": "string" },
              "web": { "type": "string" },
              "_unique": { "type": "string", "description": "Field name to use as unique key instead of codcliente." }
            },
            "additionalProperties": true
          }
        },
        "suppliers": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "codproveedor": { "type": "string" },
              "nombre": { "type": "string" },
              "razonsocial": { "type": "string" },
              "cifnif": { "type": "string" },
              "tipoidfiscal": { "type": "string" },
              "regimeniva": { "type": "string" },
              "email": { "type": "string" },
              "telefono1": { "type": "string" },
              "telefono2": { "type": "string" },
              "direccion": { "type": "string" },
              "apartado": { "type": "string" },
              "codpostal": { "type": "string" },
              "ciudad": { "type": "string" },
              "provincia": { "type": "string" },
              "codpais": { "type": "string" },
              "observaciones": { "type": "string" },
              "web": { "type": "string" },
              "_unique": { "type": "string", "description": "Field name to use as unique key instead of codproveedor." }
            },
            "additionalProperties": true
          }
        },
        "products": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["referencia"],
            "properties": {
              "referencia": { "type": "string" },
              "descripcion": { "type": "string" },
              "precio": { "type": "number" },
              "observaciones": { "type": "string" },
              "codfamilia": { "type": "string" },
              "codfabricante": { "type": "string" },
              "codimpuesto": { "type": "string" },
              "excepcioniva": { "type": "string" },
              "sevende": { "type": "boolean" },
              "secompra": { "type": "boolean" },
              "nostock": { "type": "boolean" },
              "publico": { "type": "boolean" },
              "ventasinstock": { "type": "boolean" },
              "stockfis": { "type": "number" }
            },
            "additionalProperties": true
          }
        }
      }
    },
    "install": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "codpais": { "type": "string" },
        "empresa": { "type": "string" },
        "cifnif": { "type": "string" },
        "tipoidfiscal": { "type": "string" },
        "direccion": { "type": "string" },
        "codpostal": { "type": "string" },
        "ciudad": { "type": "string" },
        "provincia": { "type": "string" },
        "regimeniva": { "type": "string" },
        "codimpuesto": { "type": "string" },
        "defaultplan": { "type": "boolean" },
        "costpricepolicy": { "type": "string" },
        "ventasinstock": { "type": "boolean" },
        "updatesupplierprices": { "type": "boolean" }
      }
    },
    "settings": {
      "type": "object"
    }
  }
}
