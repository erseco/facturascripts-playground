{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "blueprint-schema.json",
  "title": "FacturaScripts Playground Blueprint",
  "description": "Schema for browser-applied FacturaScripts Playground blueprints.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "$schema": {
      "type": "string"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "author": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    "debug": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" }
      }
    },
    "landingPage": {
      "type": "string"
    },
    "siteOptions": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "title": { "type": "string" },
        "locale": { "type": "string" },
        "timezone": { "type": "string" }
      }
    },
    "login": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "username": { "type": "string" },
        "password": { "type": "string", "minLength": 1 }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "oneOf": [
          { "type": "string" },
          {
            "type": "object",
            "additionalProperties": false,
            "required": ["name"],
            "properties": {
              "name": { "type": "string" },
              "source": {
                "oneOf": [
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "properties": {
                      "type": { "type": "string", "enum": ["bundled"] }
                    }
                  },
                  {
                    "type": "object",
                    "additionalProperties": false,
                    "required": ["url"],
                    "properties": {
                      "type": { "type": "string", "enum": ["url"] },
                      "url": { "type": "string", "format": "uri-reference" }
                    }
                  }
                ]
              }
            }
          }
        ]
      }
    }
  }
}
