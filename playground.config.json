{
  "bundleVersion": "0.1.0",
  "defaultBlueprintUrl": "./assets/blueprints/default.blueprint.json",
  "siteTitle": "FacturaScripts Playground",
  "landingPath": "/",
  "locale": "es_ES",
  "timezone": "Europe/Madrid",
  "autologin": true,
  "resetOnVersionMismatch": true,
  "outboundHttp": {
    "enabled": true,
    "allowedHosts": [
      "facturascripts.com",
      "github.com",
      "codeload.github.com"
    ],
    "allowedMethods": [
      "GET",
      "HEAD"
    ],
    "proxyPath": "/__addon_proxy__",
    "proxyUrl": "https://zip-proxy.erseco.workers.dev/",
    "timeoutMs": 15000,
    "maxBytes": 52428800
  },
  "admin": {
    "username": "admin",
    "password": "admin",
    "email": "admin@example.com"
  },
  "runtimes": [
    {
      "id": "php81-cgi",
      "label": "PHP 8.1",
      "phpVersionLabel": "8.1",
      "assetBase": "./vendor",
      "cgiWasmPath": "./vendor/php-cgi-wasm",
      "sharedLibs": [
        "dom",
        "gd",
        "iconv",
        "intl",
        "libxml",
        "sqlite",
        "simplexml",
        "zlib",
        "zip",
        "mbstring",
        "openssl",
        "phar"
      ],
      "default": false
    },
    {
      "id": "php82-cgi",
      "label": "PHP 8.2",
      "phpVersionLabel": "8.2",
      "assetBase": "./vendor",
